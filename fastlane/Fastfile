# Fastlane configuration for Omni Remote
# Distribución iOS a TestFlight

default_platform(:ios)

platform :ios do
    before_all do
        setup_ci if ENV['CI']
    end

    desc "Setup code signing from GitHub Secrets"
    lane :setup_signing do
        if is_ci
            # Create temporary keychain
            keychain_name = "fastlane_tmp_keychain"
            keychain_password = SecureRandom.uuid
        
            create_keychain(
                name: keychain_name,
                password: keychain_password,
                default_keychain: true,
                unlock: true,
                timeout: 3600,
                lock_when_sleeps: false
            )

            # Import certificate from environment variable
            import_certificate(
                certificate_path: "certificate.p12",
                certificate_password: ENV["IOS_CERTIFICATE_PASSWORD"],
                keychain_name: keychain_name,
                keychain_password: keychain_password
            )

            # Install provisioning profile
            install_provisioning_profile(
                path: "appstore.mobileprovision"
            )
        end
    end

    desc "Build iOS IPA for App Store / TestFlight"
    lane :build do
        # Setup signing
        setup_signing

        # Configure code signing settings
        update_code_signing_settings(
            use_automatic_signing: false,
            path: "ios/Runner.xcodeproj",
            team_id: ENV["FASTLANE_TEAM_ID"],
            bundle_identifier: "com.pmorales.omni.remote",
            code_sign_identity: "iPhone Distribution",
            profile_name: "match AppStore com.pmorales.omni.remote"
        )

        # Increment build number automatically
        increment_build_number(xcodeproj: "ios/Runner.xcodeproj")

        # Build IPA
        build_app(
            scheme: "production",
            workspace: "ios/Runner.xcworkspace",
            export_method: "app-store",
            output_directory: "build/ios/ipa",
            output_name: "omni_remote.ipa",
            export_team_id: ENV["FASTLANE_TEAM_ID"],
            export_options: {
                method: "app-store",
                signingStyle: "manual",
                teamID: ENV["FASTLANE_TEAM_ID"]
            }
        )
    end

    desc "Upload existing IPA to TestFlight"
    lane :upload_testflight do
        # Upload to TestFlight
        upload_to_testflight(
            ipa: "build/ios/ipa/omni_remote.ipa",
            api_key_path: "~/private_keys/AuthKey_#{ENV['APP_STORE_CONNECT_API_KEY_ID']}.p8",
            skip_waiting_for_build_processing: true,
            skip_submission: true,
            distribute_external: false,
            changelog: "Nueva versión de prueba\nCommit: #{ENV['GITHUB_SHA']}\nBuild: #{ENV['GITHUB_RUN_NUMBER']}"
        )
        
        UI.success("🎉 Build uploaded to TestFlight successfully!")
    end
end
