    #         distribute_external: false,
    #         changelog: "Nueva versión de prueba\nCommit: #{ENV['GITHUB_SHA']}\nBuild: #{ENV['GITHUB_RUN_NUMBER']}"
    #     )
        
    #     UI.success("🎉 Build uploaded to TestFlight successfully!")
    # end
end
