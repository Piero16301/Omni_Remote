# Fastlane configuration for Omni Remote
# Distribución iOS a TestFlight

default_platform(:ios)

platform :ios do
    before_all do
        setup_ci if ENV['CI']
    end

    desc "Set up manual certificates"
    lane :setup_certificates do
        import_certificate(
            certificate_path: "certificate.p12",
            certificate_password: ENV["IOS_CERTIFICATE_PASSWORD"],
            keychain_name: "login.keychain"
        )

        install_provisioning_profile(
            path: "appstore.mobileprovision"
        )
    end

    # desc "Setup code signing from GitHub Secrets"
    # lane :setup_signing do
    #     if is_ci
    #         # Create temporary keychain
    #         keychain_name = "fastlane_tmp_keychain"
    #         keychain_password = SecureRandom.uuid
        
    #         create_keychain(
    #             name: keychain_name,
    #             password: keychain_password,
    #             default_keychain: true,
    #             unlock: true,
    #             timeout: 3600,
    #             lock_when_sleeps: false
    #         )

    #         # Import certificate from environment variable
    #         import_certificate(
    #             certificate_path: "certificate.p12",
    #             certificate_password: ENV["IOS_CERTIFICATE_PASSWORD"],
    #             keychain_name: keychain_name,
    #             keychain_password: keychain_password
    #         )

    #         # Install provisioning profile
    #         install_provisioning_profile(
    #             path: "appstore.mobileprovision"
    #         )
    #     end
    # end

    desc "Build the app (archive + IPA)"
    lane :build do
        # Build the app using the production scheme and iOS workspace
        gym(
            scheme: "production",
            workspace: "ios/Runner.xcworkspace",
            export_method: "app-store",
            output_directory: "build/ios/ipa",
            output_name: "omni_remote.ipa",
            export_options: {
                uploadBitcode: false,
                uploadSymbols: true,
                compileBitcode: false
            }
        )
    end

    # desc "Build and sign IPA for App Store / TestFlight"
    # lane :build do
    #     # Setup signing (imports certificate + installs provisioning profile)
    #     setup_signing

    #     # Build and sign the IPA
    #     build_app(
    #         scheme: "production",
    #         workspace: "ios/Runner.xcworkspace",
    #         export_method: "app-store",
    #         output_directory: "build/ios/ipa",
    #         output_name: "omni_remote.ipa"
    #     )
    # end

    desc "Deploy to TestFlight"
    lane :deploy_testflight do
        # Bump local build number in the Xcode project
        # (keeps increasing on each CI run)
        increment_build_number(
            xcodeproj: "ios/Runner.xcodeproj"
        )

        # Build the app (signing is handled by the project + installed cert/profile)
        build

        # Upload to TestFlight (uses default authentication config)
        pilot(
            app_identifier: "com.pmorales.omni.remote",
            skip_waiting_for_build_processing: true,
            changelog: "Automated build from GitHub Actions",
            distribute_external: false,
            notify_external_testers: false
        )

        # Send a notification (optional)
        # slack(
        #     message: "🚀 New TestFlight build is processing!",
        #     slack_url: ENV["SLACK_WEBHOOK_URL"]
        # ) if ENV["SLACK_WEBHOOK_URL"]
    end

    # desc "Upload existing IPA to TestFlight"
    # lane :upload_testflight do
    #     # Upload to TestFlight
    #     upload_to_testflight(
    #         ipa: "build/ios/ipa/omni_remote.ipa",
